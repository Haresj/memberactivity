@model HomeViewModel
@{
    ViewData["Title"] = "Home";
}

<section class="card">
    <h1>Welcome @(Model.Name ?? "Authenticated User")</h1>
    <p><strong>Email:</strong> @(Model.Email ?? "N/A")</p>
    <p>You are signed in via OIDC authorization code flow.</p>
</section>

<section class="card">
    <h2>Saved Tokens</h2>
    <table>
        <thead>
        <tr><th>Token</th><th>Value</th></tr>
        </thead>
        <tbody>
        @foreach (var token in Model.Tokens)
        {
            <tr>
                <td>@token.Key</td>
                <td><code>@(string.IsNullOrWhiteSpace(token.Value) ? "(not available)" : token.Value)</code></td>
            </tr>
        }
        </tbody>
    </table>
</section>

<section class="card">
    <h2>User Claims</h2>
    <table>
        <thead>
        <tr><th>Type</th><th>Value</th></tr>
        </thead>
        <tbody>
        @foreach (var claim in Model.Claims)
        {
            <tr>
                <td>@claim.Type</td>
                <td>@claim.Value</td>
            </tr>
        }
        </tbody>
    </table>
</section>
